{
  "manifest_version": 2,
  "name": "Etymology Checker",
  "version": "1.0",
  "description": "Check if words are Germanic or Latinate",  
  "permissions": [
    "storage"
  ],  
  "background": {
    "scripts": ["content.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
