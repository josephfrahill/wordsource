{
  "manifest_version": 3,
  "name": "Etymology Checker",
  "version": "1.0",
  "description": "Check if words are Germanic or Latinate",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/seed-words.json"],
      "matches": ["<all_urls>"]
    }
  ]
}