{
  "manifest_version": 3,
  "name": "WordSource",
  "version": "1.0",
  "description": "View the etymological source of highlighted words; Germanic, Latinate, Greek etc.",
  "permissions": ["clipboardRead", "downloads"],
  "action": { "default_popup": "html/popup.html" },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "keyboardLookup": {
      "suggested_key": {
        "default": "Ctrl+Q"
      },
      "description": "Lookup selected word(s)"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["css/styles.css"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/words-etymology-db.json", "data/words-fetched.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
