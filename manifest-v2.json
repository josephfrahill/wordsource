{
  "manifest_version": 2,
  "name": "Etymology Checker",
  "version": "1.0",
  "description": "Check if words are Germanic or Latinate",
  "permissions": ["storage"],
  "web_accessible_resources": ["data/seed-words.json"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}