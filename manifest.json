{
  "manifest_version": 3,
  "name": "Etymology Checker",
  "version": "1.0",
  "description": "Check if words are Germanic or Latinate",
  "permissions": ["clipboardRead"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "lookup-word": {
      "suggested_key": {
        "default": "Ctrl+Q"
      },
      "description": "Lookup selected word"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/words.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
  "16": "icons/icon-16.png",
  "48": "icons/icon-48.png",
  "128": "icons/icon-128.png"
  }
}