{
  "manifest_version": 3,
  "name": "Etymology Checker",
  "version": "1.0",
  "description": "Check if words are Germanic or Latinate",
  "permissions": ["storage", "contextMenus", "activeTab", "clipboardRead", "clipboardWrite"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "lookup-word": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Lookup selected word"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/words.json"],
      "matches": ["<all_urls>"]
    }
  ]
}